<h2>Search Results for "<%= query %>"</h2>

<% if(results.length === 0) { %>
    <p>No results found</p>
<% } %>

<div>
    <% results.forEach((listing) => { %>
        <div>
            <h3>
                <a href="/listings/<%= listing._id %>">
                    <%= listing.title %>
                </a>
            </h3>
            <p><%= listing.location %></p>
        </div>
    <% }) %>
</div>